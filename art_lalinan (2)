// ===== AUTH =====
function h(s){var v=0;for(var i=0;i<s.length;i++)v=(Math.imul(31,v)+s.charCodeAt(i))|0;return v}
var HASH=h('1236qwery'),USER='adm';

function openAuthModal(){document.getElementById('authModal').classList.add('open');setTimeout(function(){document.getElementById('au').focus()},80)}
function closeAuthModal(){
  document.getElementById('authModal').classList.remove('open');
  document.getElementById('aerr').style.display='none';
  document.getElementById('au').value='';document.getElementById('ap').value='';
}
function doAuth(){
  var u=document.getElementById('au').value.trim();
  var p=document.getElementById('ap').value;
  if(u===USER&&h(p)===HASH){closeAuthModal();openAdmin();}
  else{document.getElementById('aerr').style.display='block';document.getElementById('ap').value='';}
}
document.getElementById('authModal').addEventListener('click',function(e){if(e.target===this)closeAuthModal()});

// ===== DATA =====
var defaultCareer=[
  {role:'Судебный Секретарь',org:'Федеральный суд США',desc:'Обеспечение надлежащего ведения судебного делопроизводства, управление процессуальными документами и взаимодействие с участниками разбирательств.',current:true},
  {role:'Заместитель Начальника ATD',org:'Антитеррористическое Управление',desc:'Координация оперативной деятельности антитеррористического подразделения. Разработка стратегий противодействия угрозам национальной безопасности.',current:false},
  {role:'Заместитель Директора USSS',org:'Секретная Служба США',desc:'Административное и оперативное руководство ключевым федеральным ведомством. Надзор за защитой государственных лиц, расследование финансовых преступлений.',current:false},
  {role:'Прокурор',org:'Прокуратура США',desc:'Ведение уголовных дел в интересах государства, представление обвинения в федеральных судах. Специализация на организованной преступности.',current:false}
];

function loadData(){
  try{return JSON.parse(localStorage.getItem('al3'))||null}catch(e){return null}
}
function saveData(d){try{localStorage.setItem('al3',JSON.stringify(d))}catch(e){}}

// ===== RENDER SITE =====
function renderSite(d){
  document.getElementById('v-name1').textContent=d.name1||'ART';
  document.getElementById('v-name2').textContent=d.name2||'LALINAN';
  document.getElementById('v-status').textContent=d.status||'⚖ СУДЕБНЫЙ СЕКРЕТАРЬ';
  document.getElementById('v-desc').textContent=d.desc||'';
  document.getElementById('v-s1n').textContent=d.s1n||'15+';
  document.getElementById('v-s2n').textContent=d.s2n||'3';
  document.getElementById('v-s3n').textContent=d.s3n||'100%';
  document.getElementById('v-ab1').textContent=d.ab1||'';
  document.getElementById('v-ab2').textContent=d.ab2||'';
  document.getElementById('v-quote').textContent=d.quote||'';
  document.getElementById('v-tgval').textContent=d.tg||'@i_see_waves';
  document.getElementById('v-tgcard').href=d.tgurl||'https://t.me/i_see_waves';
  document.getElementById('v-dcval').textContent=d.dc||'qwwag';
  // Current role in photo tag
  var cur=d.career&&d.career.find(function(c){return c.current});
  if(cur){
    document.getElementById('v-ptag').textContent=(d.name1||'ART')+' '+(d.name2||'LALINAN');
    document.getElementById('v-prole').textContent=cur.role;
    document.getElementById('v-status').textContent='⚖ '+cur.role;
  }
  // Timeline
  var tl=document.getElementById('careerTimeline');
  tl.innerHTML='';
  (d.career||defaultCareer).forEach(function(c){
    var div=document.createElement('div');
    div.className='titem'+(c.current?' current':'');
    div.innerHTML='<div class="tcard"><div class="trole">'+escH(c.role)+'</div><div class="torg">'+escH(c.org)+'</div><div class="tdesc">'+escH(c.desc)+'</div><div class="tbadge'+(c.current?' current':'')+'">'+( c.current?'● Текущая должность':'Прошлая должность')+'</div></div>';
    tl.appendChild(div);
  });
}

function escH(s){var d=document.createElement('div');d.appendChild(document.createTextNode(s));return d.innerHTML}

// ===== ADMIN PANEL =====
function openAdmin(){
  var d=loadData()||getDefaults();
  // Fill fields
  document.getElementById('f-name1').value=d.name1||'ART';
  document.getElementById('f-name2').value=d.name2||'LALINAN';
  document.getElementById('f-status').value=d.status||'';
  document.getElementById('f-desc').value=d.desc||'';
  document.getElementById('f-s1n').value=d.s1n||'15+';
  document.getElementById('f-s2n').value=d.s2n||'3';
  document.getElementById('f-s3n').value=d.s3n||'100%';
  document.getElementById('f-ab1').value=d.ab1||'';
  document.getElementById('f-ab2').value=d.ab2||'';
  document.getElementById('f-quote').value=d.quote||'';
  document.getElementById('f-tg').value=d.tg||'@i_see_waves';
  document.getElementById('f-tgurl').value=d.tgurl||'https://t.me/i_see_waves';
  document.getElementById('f-dc').value=d.dc||'qwwag';
  // Render career list
  renderCareerAdmin(d.career||defaultCareer);
  document.getElementById('adminOverlay').classList.add('open');
}

function closeAdmin(){document.getElementById('adminOverlay').classList.remove('open')}
document.getElementById('adminOverlay').addEventListener('click',function(e){if(e.target===this)closeAdmin()});

function renderCareerAdmin(list){
  var cl=document.getElementById('careerList');
  cl.innerHTML='';
  list.forEach(function(c,i){
    var div=document.createElement('div');
    div.className='career-item-admin'+(c.current?' is-current':'');
    div.dataset.idx=i;
    div.innerHTML=
      '<div class="ci-fields">'+
        '<input type="text" placeholder="Должность" value="'+escAttr(c.role)+'" onchange="ciUpdate('+i+',\'role\',this.value)">'+
        '<input type="text" placeholder="Организация" value="'+escAttr(c.org)+'" onchange="ciUpdate('+i+',\'org\',this.value)" style="max-width:220px">'+
        '<input type="text" placeholder="Описание" value="'+escAttr(c.desc)+'" onchange="ciUpdate('+i+',\'desc\',this.value)" style="flex:2">'+
      '</div>'+
      '<button class="ci-current-toggle'+(c.current?' active':'')+'" onclick="ciSetCurrent('+i+')" title="Отметить как текущую">'+(c.current?'★ ТЕКУЩАЯ':'☆ ТЕКУЩАЯ')+'</button>'+
      '<button class="ci-remove" onclick="ciRemove('+i+')" title="Удалить">✕</button>';
    cl.appendChild(div);
  });
}

function escAttr(s){return (s||'').replace(/"/g,'&quot;')}

var tmpCareer=null;
function getTmpCareer(){
  if(!tmpCareer){
    var d=loadData();
    tmpCareer=d?JSON.parse(JSON.stringify(d.career||defaultCareer)):JSON.parse(JSON.stringify(defaultCareer));
  }
  return tmpCareer;
}

function ciUpdate(i,key,val){getTmpCareer()[i][key]=val}
function ciRemove(i){getTmpCareer().splice(i,1);renderCareerAdmin(getTmpCareer())}
function ciSetCurrent(i){
  getTmpCareer().forEach(function(c){c.current=false});
  getTmpCareer()[i].current=true;
  renderCareerAdmin(getTmpCareer());
}
function addCareer(){
  getTmpCareer().unshift({role:'Новая должность',org:'Организация',desc:'Описание обязанностей',current:false});
  renderCareerAdmin(getTmpCareer());
}

function collectData(){
  return {
    name1:document.getElementById('f-name1').value.trim(),
    name2:document.getElementById('f-name2').value.trim(),
    status:document.getElementById('f-status').value.trim(),
    desc:document.getElementById('f-desc').value.trim(),
    s1n:document.getElementById('f-s1n').value.trim(),
    s2n:document.getElementById('f-s2n').value.trim(),
    s3n:document.getElementById('f-s3n').value.trim(),
    ab1:document.getElementById('f-ab1').value.trim(),
    ab2:document.getElementById('f-ab2').value.trim(),
    quote:document.getElementById('f-quote').value.trim(),
    tg:document.getElementById('f-tg').value.trim(),
    tgurl:document.getElementById('f-tgurl').value.trim(),
    dc:document.getElementById('f-dc').value.trim(),
    career:getTmpCareer()
  };
}

function applyAndSave(){
  var d=collectData();
  saveData(d);
  renderSite(d);
  tmpCareer=null;
  closeAdmin();
  toast('✓ СОХРАНЕНО');
}

function resetAll(){
  if(!confirm('Сбросить все данные к дефолтным?'))return;
  localStorage.removeItem('al3');
  tmpCareer=null;
  renderSite(getDefaults());
  closeAdmin();
  toast('СБРОШЕНО');
}

function getDefaults(){
  return {
    name1:'ART',name2:'LALINAN',
    status:'⚖ СУДЕБНЫЙ СЕКРЕТАРЬ',
    desc:'Профессионал с многолетним опытом работы в системе права и правопорядка США. Прошёл путь от прокурора до высших руководящих должностей в федеральных структурах.',
    s1n:'15+',s2n:'3',s3n:'100%',
    ab1:'Art Lalinan — юрист и государственный служащий, чья карьера охватывает более полутора десятилетий работы в правоохранительных и судебных органах США.',
    ab2:'Во время работы в Секретной службе США (USSS) в должности заместителя директора, Art Lalinan руководил крупными операциями и реформировал внутренние процессы ведомства.',
    quote:'«Закон — это не инструмент власти. Это щит, который защищает каждого гражданина.»',
    tg:'@i_see_waves',tgurl:'https://t.me/i_see_waves',dc:'qwwag',
    career:defaultCareer
  };
}

function toast(msg){
  var t=document.createElement('div');t.className='toast';t.textContent=msg;
  document.body.appendChild(t);
  setTimeout(function(){t.style.opacity='0';setTimeout(function(){t.remove()},400)},2200);
}

// ===== INIT =====
(function(){
  var d=loadData()||getDefaults();
  renderSite(d);
})();
</script>
