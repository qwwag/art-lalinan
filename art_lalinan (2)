<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ART LALINAN — Official</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0a0a0f;--surface:#0f0f17;--surface2:#141420;--border:#1c1c2e;
  --accent:#e63946;--accent2:#ff6b35;--gold:#ffd60a;--text:#e2e2f0;
  --muted:#5a5a7a;--glow:rgba(230,57,70,0.25);
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;min-height:100vh;overflow-x:hidden}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.025) 3px,rgba(0,0,0,0.025) 4px);pointer-events:none;z-index:9998}

/* ===== ADMIN PANEL OVERLAY ===== */
#adminOverlay{
  position:fixed;inset:0;background:rgba(5,5,10,0.96);
  display:none;align-items:flex-start;justify-content:center;
  z-index:3000;overflow-y:auto;padding:20px;
  backdrop-filter:blur(8px);
}
#adminOverlay.open{display:flex}

.admin-panel{
  background:var(--surface);border:1px solid var(--border);
  width:100%;max-width:900px;margin:auto;position:relative;
}
.admin-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent)}

.admin-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:22px 32px;border-bottom:1px solid var(--border);
}
.admin-header-title{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:5px;color:var(--accent)}
.admin-header-sub{font-family:'Share Tech Mono',monospace;font-size:0.62rem;color:var(--muted);letter-spacing:3px;margin-top:2px}
.admin-close{background:none;border:1px solid var(--border);color:var(--muted);width:36px;height:36px;cursor:pointer;font-size:1.1rem;transition:all 0.2s;font-family:'Share Tech Mono',monospace}
.admin-close:hover{border-color:var(--accent);color:var(--accent)}

.admin-body{padding:32px}
.admin-section{margin-bottom:36px}
.admin-section-title{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:3px;color:var(--muted);margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.admin-section-title::before{content:'';width:3px;height:18px;background:var(--accent)}

.afield{margin-bottom:14px}
.afield label{display:block;font-family:'Share Tech Mono',monospace;font-size:0.62rem;letter-spacing:2px;color:var(--muted);margin-bottom:6px;text-transform:uppercase}
.afield input,.afield textarea{
  width:100%;background:#07070e;border:1px solid var(--border);
  color:var(--text);padding:10px 14px;font-family:'Rajdhani',sans-serif;
  font-size:1rem;outline:none;transition:border-color 0.2s;resize:vertical;
}
.afield textarea{min-height:80px}
.afield input:focus,.afield textarea:focus{border-color:var(--accent)}

/* Career list in admin */
.career-list{display:flex;flex-direction:column;gap:12px;margin-bottom:16px}
.career-item-admin{
  background:var(--surface2);border:1px solid var(--border);
  padding:16px 18px;display:flex;align-items:center;gap:12px;
  border-left:3px solid var(--border);transition:border-color 0.2s;
}
.career-item-admin.is-current{border-left-color:var(--gold)}
.career-item-admin:not(.is-current){border-left-color:var(--accent)}
.ci-fields{flex:1;display:flex;gap:10px;flex-wrap:wrap}
.ci-fields input{background:#07070e;border:1px solid var(--border);color:var(--text);padding:8px 12px;font-family:'Rajdhani',sans-serif;font-size:0.95rem;outline:none;transition:border-color 0.2s;flex:1;min-width:140px}
.ci-fields input:focus{border-color:var(--accent)}
.ci-current-toggle{
  background:transparent;border:1px solid var(--border);color:var(--muted);
  padding:6px 12px;font-family:'Share Tech Mono',monospace;font-size:0.6rem;
  letter-spacing:2px;cursor:pointer;white-space:nowrap;transition:all 0.2s;
}
.ci-current-toggle.active{background:var(--gold);border-color:var(--gold);color:#000}
.ci-remove{background:transparent;border:1px solid var(--border);color:var(--muted);width:32px;height:32px;cursor:pointer;font-size:1rem;transition:all 0.2s;flex-shrink:0}
.ci-remove:hover{border-color:var(--accent);color:var(--accent)}

.add-career-btn{
  width:100%;background:transparent;border:1px dashed var(--border);
  color:var(--muted);padding:12px;font-family:'Rajdhani',sans-serif;
  font-weight:600;font-size:0.85rem;letter-spacing:3px;cursor:pointer;
  text-transform:uppercase;transition:all 0.2s;
}
.add-career-btn:hover{border-color:var(--accent);color:var(--accent)}

.admin-actions{display:flex;gap:12px;padding:20px 32px;border-top:1px solid var(--border)}
.abtn{
  padding:12px 28px;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;
  letter-spacing:4px;cursor:pointer;border:none;transition:all 0.2s;
}
.abtn.primary{background:var(--accent);color:#fff}
.abtn.primary:hover{background:#c1121f;box-shadow:0 0 20px var(--glow)}
.abtn.ghost{background:transparent;border:1px solid var(--border);color:var(--muted)}
.abtn.ghost:hover{border-color:var(--accent);color:var(--accent)}

/* ===== AUTH MODAL ===== */
#authModal{
  position:fixed;inset:0;background:rgba(5,5,10,0.94);
  display:none;align-items:center;justify-content:center;
  z-index:4000;backdrop-filter:blur(6px);
}
#authModal.open{display:flex}
.auth-box{background:var(--surface);border:1px solid var(--border);padding:40px 36px;width:320px;position:relative}
.auth-box::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--accent),transparent)}
.auth-title{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:5px;color:var(--accent);text-align:center;margin-bottom:4px}
.auth-sub{font-family:'Share Tech Mono',monospace;font-size:0.62rem;color:var(--muted);letter-spacing:3px;text-align:center;margin-bottom:28px}
.af{margin-bottom:15px}
.af label{display:block;font-family:'Share Tech Mono',monospace;font-size:0.62rem;letter-spacing:3px;color:var(--muted);margin-bottom:6px}
.af input{width:100%;background:#07070e;border:1px solid var(--border);color:var(--text);padding:12px 14px;font-family:'Share Tech Mono',monospace;font-size:0.9rem;outline:none;transition:border-color 0.2s}
.af input:focus{border-color:var(--accent)}
.auth-btn{width:100%;background:var(--accent);border:none;color:#fff;padding:13px;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:5px;cursor:pointer;transition:all 0.2s;margin-top:6px}
.auth-btn:hover{background:#c1121f;box-shadow:0 0 24px var(--glow)}
.auth-err{display:none;color:var(--accent);font-family:'Share Tech Mono',monospace;font-size:0.62rem;letter-spacing:2px;text-align:center;margin-top:12px}
.acorner{position:absolute;width:10px;height:10px}
.acorner.tl{top:7px;left:7px;border-top:1px solid var(--gold);border-left:1px solid var(--gold)}
.acorner.tr{top:7px;right:7px;border-top:1px solid var(--gold);border-right:1px solid var(--gold)}
.acorner.bl{bottom:7px;left:7px;border-bottom:1px solid var(--gold);border-left:1px solid var(--gold)}
.acorner.br{bottom:7px;right:7px;border-bottom:1px solid var(--gold);border-right:1px solid var(--gold)}

/* ===== NAV ===== */
nav{position:fixed;top:0;left:0;right:0;z-index:500;background:rgba(10,10,15,0.97);border-bottom:1px solid var(--border);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:space-between;padding:0 48px;height:60px}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:6px;color:var(--accent)}
.nav-logo span{color:var(--text)}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{font-weight:600;font-size:0.8rem;letter-spacing:2px;color:var(--muted);text-decoration:none;text-transform:uppercase;transition:color 0.2s}
.nav-links a:hover{color:var(--accent)}
.admin-btn{background:transparent;border:1px solid var(--border);color:var(--muted);padding:7px 18px;font-family:'Rajdhani',sans-serif;font-weight:600;font-size:0.75rem;letter-spacing:2px;cursor:pointer;text-transform:uppercase;transition:all 0.2s}
.admin-btn:hover{border-color:var(--accent);color:var(--accent)}

/* ===== HERO ===== */
#home{min-height:100vh;display:flex;align-items:center;padding:100px 48px 60px;position:relative;overflow:hidden}
#home::before{content:'';position:absolute;right:-200px;top:50%;transform:translateY(-50%);width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(230,57,70,0.06) 0%,transparent 70%);pointer-events:none}
.hero-grid{display:grid;grid-template-columns:1fr auto;gap:80px;max-width:1200px;margin:0 auto;width:100%;align-items:center}
.hero-eyebrow{font-family:'Share Tech Mono',monospace;font-size:0.7rem;color:var(--accent);letter-spacing:5px;margin-bottom:18px;display:flex;align-items:center;gap:14px}
.hero-eyebrow::before{content:'';width:36px;height:1px;background:var(--accent)}
h1.hero-name{font-family:'Bebas Neue',sans-serif;font-size:7rem;line-height:0.88;letter-spacing:3px;margin-bottom:28px}
h1.hero-name .red{color:var(--accent)}
.hero-status{display:inline-flex;align-items:center;gap:10px;background:var(--accent);padding:9px 22px;font-family:'Rajdhani',sans-serif;font-weight:700;font-size:1rem;letter-spacing:3px;text-transform:uppercase;margin-bottom:28px}
.hero-status::before{content:'';width:8px;height:8px;background:#fff;border-radius:50%;animation:blink 1.5s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
.hero-desc{font-size:1.05rem;line-height:1.8;color:#8888aa;max-width:500px}
.stats-row{display:flex;gap:36px;margin-top:40px;padding-top:40px;border-top:1px solid var(--border)}
.stat{border-left:2px solid var(--accent);padding-left:16px}
.stat-n{font-family:'Bebas Neue',sans-serif;font-size:2.4rem;color:var(--accent);line-height:1}
.stat-l{font-size:0.72rem;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-top:2px}

/* PHOTO FRAME */
.photo-side{position:relative;flex-shrink:0}
.photo-frame{position:relative;width:320px;height:400px}
.photo-frame::before{content:'';position:absolute;inset:-2px;background:linear-gradient(135deg,var(--accent) 0%,rgba(230,57,70,0) 50%,var(--accent2) 100%);z-index:0}
.photo-frame img{position:relative;z-index:1;width:100%;height:100%;object-fit:cover;object-position:top center;display:block}
.pcorner{position:absolute;width:18px;height:18px;z-index:3}
.pcorner.tl{top:4px;left:4px;border-top:2px solid var(--gold);border-left:2px solid var(--gold)}
.pcorner.tr{top:4px;right:4px;border-top:2px solid var(--gold);border-right:2px solid var(--gold)}
.pcorner.bl{bottom:4px;left:4px;border-bottom:2px solid var(--gold);border-left:2px solid var(--gold)}
.pcorner.br{bottom:4px;right:4px;border-bottom:2px solid var(--gold);border-right:2px solid var(--gold)}
.photo-shadow{position:absolute;bottom:-16px;right:-16px;width:100%;height:100%;border:1px solid var(--border);z-index:-1}
.photo-tag{position:absolute;bottom:-22px;left:-12px;background:var(--surface2);border:1px solid var(--border);border-left:3px solid var(--accent);padding:10px 16px;z-index:4}
.photo-tag-name{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:3px}
.photo-tag-role{font-family:'Share Tech Mono',monospace;font-size:0.62rem;color:var(--accent);letter-spacing:2px;margin-top:3px}

/* ===== CAREER ===== */
#career{padding:100px 0;background:var(--surface);width:100%;max-width:100%}
.section-inner{max-width:1200px;margin:0 auto;padding:0 48px}
.section-label{font-family:'Share Tech Mono',monospace;font-size:0.68rem;color:var(--accent);letter-spacing:6px;text-transform:uppercase;margin-bottom:10px}
.section-title{font-family:'Bebas Neue',sans-serif;font-size:4rem;letter-spacing:3px;margin-bottom:60px;position:relative;display:inline-block}
.section-title::after{content:'';position:absolute;bottom:-6px;left:0;width:55%;height:2px;background:linear-gradient(90deg,var(--accent),transparent)}
.timeline{position:relative;padding-left:48px}
.timeline::before{content:'';position:absolute;left:6px;top:0;bottom:0;width:1px;background:linear-gradient(180deg,var(--accent),rgba(230,57,70,0.1))}
.titem{position:relative;margin-bottom:24px}
.titem::before{content:'';position:absolute;left:-48px;top:24px;width:12px;height:12px;background:var(--accent);border:2px solid var(--bg)}
.titem.current::before{background:var(--gold);box-shadow:0 0 12px rgba(255,214,10,0.5)}
.tcard{background:var(--surface2);border:1px solid var(--border);border-left:3px solid var(--accent);padding:24px 28px;transition:all 0.3s}
.titem.current .tcard{border-left-color:var(--gold)}
.tcard:hover{box-shadow:-4px 0 24px var(--glow);transform:translateX(4px)}
.trole{font-family:'Bebas Neue',sans-serif;font-size:1.9rem;letter-spacing:2px;margin-bottom:5px;line-height:1.1}
.torg{font-size:0.82rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;font-weight:600;margin-bottom:12px}
.tdesc{font-size:1rem;color:#8888aa;line-height:1.65}
.tbadge{display:inline-block;padding:3px 12px;font-family:'Share Tech Mono',monospace;font-size:0.6rem;letter-spacing:2px;text-transform:uppercase;margin-top:12px;border:1px solid var(--border);color:var(--muted)}
.tbadge.current{background:var(--accent);border-color:var(--accent);color:#fff;box-shadow:0 0 12px var(--glow)}

/* ===== ABOUT ===== */
#about{padding:100px 48px;max-width:1200px;margin:0 auto}
.about-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:72px;align-items:start}
.about-text p{margin-bottom:20px;font-size:1.05rem;line-height:1.85;color:#8888aa}
.qblock{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--gold);padding:22px 26px;margin-top:28px}
.qblock p{font-size:1.05rem;font-style:italic;color:var(--text);line-height:1.7}
.skills-box{background:var(--surface);border:1px solid var(--border);padding:32px}
.skills-box h3{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:2px;margin-bottom:20px;color:var(--accent)}
.skill-item{display:flex;align-items:center;gap:14px;padding:13px 0;border-bottom:1px solid var(--border);font-weight:600;font-size:1rem;letter-spacing:1px}
.skill-item:last-child{border:none}
.skill-item::before{content:'▸';color:var(--accent);font-size:0.75rem;flex-shrink:0}

/* ===== CONTACTS ===== */
#contacts{padding:80px 0;background:var(--surface);width:100%;max-width:100%}
.contacts-inner{max-width:1200px;margin:0 auto;padding:0 48px}
.contact-cards{display:flex;gap:24px;flex-wrap:wrap;margin-top:40px}
.ccard{display:flex;align-items:center;gap:18px;background:var(--surface2);border:1px solid var(--border);padding:22px 28px;flex:1;min-width:240px;transition:all 0.3s;text-decoration:none;color:var(--text);position:relative}
.ccard::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;transition:width 0.3s}
.ccard:hover{transform:translateY(-3px);box-shadow:0 8px 32px rgba(0,0,0,0.4)}
.ccard:hover::before{width:5px}
.ccard.tg::before{background:#29b6f6}
.ccard.dc::before{background:#7289da}
.ccard-icon{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;border:1px solid var(--border)}
.ccard.tg .ccard-icon{border-color:rgba(41,182,246,0.3);color:#29b6f6}
.ccard.dc .ccard-icon{border-color:rgba(114,137,218,0.3);color:#7289da}
.ccard-label{font-family:'Share Tech Mono',monospace;font-size:0.62rem;letter-spacing:3px;color:var(--muted);margin-bottom:5px}
.ccard-value{font-family:'Bebas Neue',sans-serif;font-size:1.25rem;letter-spacing:2px}
.ccard.tg .ccard-value{color:#29b6f6}
.ccard.dc .ccard-value{color:#7289da}
.ccard-arrow{margin-left:auto;color:var(--muted);transition:transform 0.2s;flex-shrink:0}
.ccard:hover .ccard-arrow{transform:translateX(4px);color:var(--accent)}

/* ===== FOOTER ===== */
footer{background:var(--bg);border-top:1px solid var(--border);padding:36px 48px;display:flex;align-items:center;justify-content:space-between}
.footer-logo{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:6px;color:var(--accent)}
.footer-copy{font-family:'Share Tech Mono',monospace;font-size:0.65rem;color:var(--muted);letter-spacing:2px}

/* Toast */
.toast{position:fixed;bottom:28px;right:28px;background:var(--accent);color:#fff;padding:11px 22px;font-family:'Share Tech Mono',monospace;font-size:0.68rem;letter-spacing:3px;z-index:9999;pointer-events:none;transition:opacity 0.4s}

@media(max-width:900px){
  .hero-grid{grid-template-columns:1fr}
  .photo-side{display:flex;justify-content:center;margin-top:20px}
  .about-grid{grid-template-columns:1fr}
  nav{padding:0 16px}
  .nav-links{display:none}
  #home,#about{padding-left:16px;padding-right:16px}
  .section-inner,.contacts-inner{padding:0 16px}
  h1.hero-name{font-size:4.5rem}
  footer{flex-direction:column;gap:12px;text-align:center}
}
</style>
</head>
<body>

<!-- AUTH MODAL -->
<div id="authModal">
  <div class="auth-box">
    <div class="acorner tl"></div><div class="acorner tr"></div>
    <div class="acorner bl"></div><div class="acorner br"></div>
    <div class="auth-title">ADMIN</div>
    <div class="auth-sub">// ПАНЕЛЬ УПРАВЛЕНИЯ //</div>
    <div class="af"><label>Логин</label><input id="au" type="text" placeholder="логин" autocomplete="off" onkeydown="if(event.key==='Enter')doAuth()"></div>
    <div class="af"><label>Пароль</label><input id="ap" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')doAuth()"></div>
    <button class="auth-btn" onclick="doAuth()">ВОЙТИ</button>
    <div class="auth-err" id="aerr">// НЕВЕРНЫЕ ДАННЫЕ //</div>
  </div>
</div>

<!-- ADMIN PANEL -->
<div id="adminOverlay">
  <div class="admin-panel">
    <div class="admin-header">
      <div>
        <div class="admin-header-title">⚙ ПАНЕЛЬ УПРАВЛЕНИЯ</div>
        <div class="admin-header-sub">// ART LALINAN — РЕДАКТИРОВАНИЕ КОНТЕНТА //</div>
      </div>
      <button class="admin-close" onclick="closeAdmin()">✕</button>
    </div>
    <div class="admin-body">

      <!-- HERO -->
      <div class="admin-section">
        <div class="admin-section-title">ГЛАВНЫЙ БЛОК</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
          <div class="afield"><label>Имя (строка 1)</label><input id="f-name1" type="text" value="ART"></div>
          <div class="afield"><label>Имя (строка 2)</label><input id="f-name2" type="text" value="LALINAN"></div>
        </div>
        <div class="afield"><label>Текущий статус / должность</label><input id="f-status" type="text" value="⚖ СУДЕБНЫЙ СЕКРЕТАРЬ"></div>
        <div class="afield"><label>Описание</label><textarea id="f-desc">Профессионал с многолетним опытом работы в системе права и правопорядка США. Прошёл путь от прокурора до высших руководящих должностей в федеральных структурах. Известен принципиальностью и строгим следованием закону.</textarea></div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px">
          <div class="afield"><label>Стат 1 (число)</label><input id="f-s1n" type="text" value="15+"></div>
          <div class="afield"><label>Стат 2 (число)</label><input id="f-s2n" type="text" value="3"></div>
          <div class="afield"><label>Стат 3 (число)</label><input id="f-s3n" type="text" value="100%"></div>
        </div>
      </div>

      <!-- CAREER -->
      <div class="admin-section">
        <div class="admin-section-title">ДОЛЖНОСТИ</div>
        <div class="career-list" id="careerList"></div>
        <button class="add-career-btn" onclick="addCareer()">+ ДОБАВИТЬ ДОЛЖНОСТЬ</button>
      </div>

      <!-- ABOUT -->
      <div class="admin-section">
        <div class="admin-section-title">О ПЕРСОНЕ</div>
        <div class="afield"><label>Параграф 1</label><textarea id="f-ab1">Art Lalinan — юрист и государственный служащий, чья карьера охватывает более полутора десятилетий работы в правоохранительных и судебных органах США.</textarea></div>
